# Dashboard server
PORT=3000
HOST=127.0.0.1

# Set to false when connecting to a real server. Demo mode is enabled by default.
PALWORLD_DEMO_MODE=true

# Palworld REST API (RESTAPIEnabled=True, RESTAPIPort=8212)
PALWORLD_API_URL=http://127.0.0.1:8212
PALWORLD_ADMIN_USERNAME=admin
PALWORLD_ADMIN_PASSWORD=change-me

# Optional daily random schedule (Windows host)
# The Node dashboard process must remain running for the schedule to work.
PALWORLD_SCHEDULE_ENABLED=false
PALWORLD_START_WINDOW=19:30-20:30
PALWORLD_STOP_WINDOW=01:00-01:30
PALWORLD_SERVER_COMMAND=C:\PalServer\PalServer.exe
PALWORLD_SERVER_CWD=C:\PalServer
PALWORLD_SETTINGS_PATH=C:\PalServer\Pal\Saved\Config\WindowsServer\PalWorldSettings.ini
# JSON array of command-line arguments, for example: ["-useperfthreads", "-NoAsyncLoadingThread"]
PALWORLD_SERVER_ARGS_JSON=[]

# Optional automatic Google Drive backup after each confirmed shutdown.
# Requires rclone and a configured Google Drive remote, for example: rclone config.
PALWORLD_BACKUP_ENABLED=false
PALWORLD_SAVE_PATH=C:\PalServer\Pal\Saved\SaveGames
PALWORLD_BACKUP_REMOTE=gdrive:palworld-backups
RCLONE_COMMAND=rclone
PALWORLD_BACKUP_TIMEOUT_MS=600000

# Optional Discord webhook notifications for scheduled start/shutdown
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_USERNAME=Palworld Server
